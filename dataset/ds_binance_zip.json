{
	"name": "ds_binance_zip",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_http_binance",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"symbol": {
				"type": "string",
				"defaultValue": "@item().symbol"
			},
			"interval": {
				"type": "string",
				"defaultValue": "@item().interval"
			},
			"date": {
				"type": "string",
				"defaultValue": "@pipeline().parameters.run_date"
			}
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "HttpServerLocation",
				"relativeUrl": {
					"value": "@concat('data/spot/daily/klines/', dataset().symbol, '/', dataset().interval, '/', dataset().symbol, '-', dataset().interval, '-', dataset().date, '.zip')",
					"type": "Expression"
				}
			},
			"compression": {
				"type": "bzip2",
				"level": "Optimal"
			}
		}
	}
}