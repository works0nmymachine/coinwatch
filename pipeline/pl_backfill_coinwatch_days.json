{
	"name": "pl_backfill_coinwatch_days",
	"properties": {
		"activities": [
			{
				"name": "ForEachDay",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@range(1, pipeline().parameters.days_back)",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "RunDailyCoinwatchPipeline",
							"type": "ExecutePipeline",
							"dependsOn": [],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "pl_load_binance_klines_bronze",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"run_date": {
										"value": "@formatDateTime(\n    addDays(utcNow(), mul(item(), -1)),\n    'yyyy-MM-dd'\n)",
										"type": "Expression"
									}
								}
							}
						}
					]
				}
			}
		],
		"parameters": {
			"days_back": {
				"type": "int",
				"defaultValue": 60
			}
		},
		"annotations": []
	}
}